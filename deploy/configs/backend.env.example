# =====================================================================
# NXT8 backend/.env — production template
# Copy to /app/backend/.env on the VPS and fill in real keys.
# =====================================================================

# ---- MongoDB ----
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=nxt8

# ---- CORS ----
# Производственный домен (или несколько через запятую). НЕ ставить * в проде.
CORS_ORIGINS=https://nxt8.pro,https://www.nxt8.pro

# ---- LLM (DeepSeek через OpenRouter) — ОБЯЗАТЕЛЬНО ----
# Получить: https://openrouter.ai/keys (минимум $10 на балансе)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_REFERRER=https://nxt8.pro

# (опционально) DeepSeek direct как fallback если OpenRouter недоступен
# Получить: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-REPLACE_ME

# ---- Voice (OpenAI Whisper + TTS) — ОБЯЗАТЕЛЬНО для голоса ----
# Получить: https://platform.openai.com/api-keys
# Примерные расходы: $0.006/мин транскрипции + $15/1M символов TTS
OPENAI_API_KEY=sk-REPLACE_ME

# ---- MemPalace (ChromaDB long-term memory) ----
MEMPALACE_ENABLED=true
MEMPALACE_PATH=/home/nxt8/app/data/mempalace
# При первом запуске скачивается embedding модель (~79 MB).
# Прогрев: curl -X POST $HOST/api/mempalace/store -H "Content-Type: application/json" \
#   -d '{"wing":"company","room":"policies","drawer":"intro","content":"NXT8 deployed","metadata":{}}'

# ---- Hermes Gateway (опционально, можно не поднимать) ----
# Если оставить HERMES_API_KEY пустым — Hermes fallback на DeepSeek прямой путь.
# Это нормально для пилота и большинства сценариев.
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=

# ---- Frontend публичный URL (для CORS preflight некоторых сценариев) ----
APP_PUBLIC_URL=https://nxt8.pro

# ---- Логирование ----
LOG_LEVEL=INFO
